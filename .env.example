# ============================================
# Bill Split Backend - Environment Configuration
# ============================================
# Copy this file to .env and adjust values as needed
# Most defaults work out of the box for local development
#
# To start: docker-compose up -d
# API: http://localhost:8000
# Docs: http://localhost:8000/docs

# ========================
# APP SETTINGS
# ========================

# Project name (shown in API docs)
PROJECT_NAME="Bill Split API"

# Environment: local, staging, production
# Set to "production" for real deployments
ENVIRONMENT=local

# Backend port
BACKEND_PORT=8000

# ========================
# CORS (Cross-Origin)
# ========================
# Allow requests from these origins
# For mobile app development, add your emulator/device IP here
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:3000,http://localhost:8000,http://10.0.2.2,http://127.0.0.1"

# ========================
# SECURITY
# ========================
# Generate a new secret key for production:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Default admin user (created on first run)
FIRST_SUPERUSER=admin@billsplit.local
FIRST_SUPERUSER_PASSWORD=Admin123!@#

# ========================
# DATABASE (PostgreSQL)
# ========================
# Default values work with Docker Compose
# Change POSTGRES_PASSWORD for production!
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=billsplit
POSTGRES_USER=billsplit
POSTGRES_PASSWORD=billsplit123

# ========================
# EMAIL (Optional)
# ========================
# Leave empty to disable email features
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@billsplit.local
SMTP_TLS=True
SMTP_PORT=587

# ========================
# ERROR TRACKING (Optional)
# ========================
# Get Sentry DSN from https://sentry.io if needed
SENTRY_DSN=