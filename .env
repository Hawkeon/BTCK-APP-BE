# Backend API
PROJECT_NAME="Expense Tracker API"
STACK_NAME=expense-tracker

# Environment: local, staging, production
ENVIRONMENT=local

# CORS - allow mobile app origins
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:8000"

# Security
SECRET_KEY=changethis-replace-with-secure-key
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis-replace

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=expense_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis-replace

# Email (optional - disable if not needed)
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Error tracking
SENTRY_DSN=